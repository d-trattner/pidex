{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PIDEX local operator contract overrides",
  "type": "object",
  "required": ["version", "overrides"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "operator_type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pending", "approved", "rejected", "superseded"] },
          "operator_type": { "type": "string", "minLength": 1 },
          "contract_id": { "type": ["string", "null"] },
          "change_type": { "type": "string" },
          "old_value": {},
          "new_value": {},
          "reason": { "type": "string" },
          "approved_by": { "type": "string" },
          "approved_at": { "type": "string" },
          "effective_from": { "type": "string" },
          "source_decision_id": { "type": ["string", "null"] },
          "historical_reclassification": { "enum": ["future-only", "reclassify-matching-history", "manual-only"] },
          "contract_patch": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
