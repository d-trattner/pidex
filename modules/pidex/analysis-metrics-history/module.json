{
  "id": "pidex.analysis-metrics-history",
  "schema_version": 1,
  "name": "PIDEX Analysis, Metrics, and History",
  "kind": "optional-internal",
  "default_enabled": true,
  "dependencies": [
    "pidex.core"
  ],
  "capabilities": [
    {
      "id": "analysis-metrics-history.record-event",
      "kind": "tool",
      "phases": [
        "planning",
        "implementation",
        "code-review",
        "qa",
        "uat",
        "devops",
        "maintenance"
      ],
      "scope": "project",
      "importance": "optional",
      "allowed_agents": [
        "orchestrator",
        "pidex-planner",
        "pidex-implementer",
        "pidex-code-reviewer",
        "pidex-qa",
        "pidex-uat",
        "pidex-devops",
        "pidex-pi"
      ],
      "supported_platforms": [
        "linux",
        "wsl2",
        "windows-git-bash"
      ],
      "mutability": [
        "writes-artifacts"
      ],
      "command": {
        "bin": "node",
        "args": [
          "modules/pidex/analysis-metrics-history/scripts/pipeline/event.mjs"
        ],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": [
            "^--(project|state-dir|event|source|actor|status|plan|pipeline-id|test-project)$",
            "^[A-Za-z0-9 ._:/=@-]+$"
          ],
          "allow_absolute_project_paths": true
        }
      }
    },
    {
      "id": "analysis-metrics-history.history-append",
      "kind": "tool",
      "phases": [
        "planning",
        "implementation",
        "code-review",
        "qa",
