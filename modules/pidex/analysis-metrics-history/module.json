        "windows-git-bash"
      ],
      "mutability": [
        "writes-artifacts"
      ],
      "command": {
        "bin": "bash",
        "args": [
          "modules/pidex/analysis-metrics-history/scripts/history/append.sh"
        ],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": [
            "^--[A-Za-z0-9-]+$",
            "^[A-Za-z0-9 ._:/=@+-]+$"
          ],
          "allow_absolute_project_paths": true
        }
      }
    },
    {
