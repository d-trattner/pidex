{
  "id": "pidex.project-pipeline",
  "schema_version": 1,
  "name": "PIDEX Project Pipeline",
  "kind": "optional-internal",
  "default_enabled": true,
  "dependencies": ["pidex.core"],
  "agent_rules": [
    {
      "id": "pidex.project-pipeline.browser-smoke.qa-request",
      "agent": "pidex-qa",
      "phases": ["qa"],
      "path": "rules/pidex-qa/browser-smoke-request.md",
      "authority": "module-scoped",
      "summary": "Project Pipeline QA browser-smoke request rules",
      "audience_scope": "project-pipeline",
      "applies_when": { "mode": "project-pipeline", "capabilities": ["project-pipeline.browser-smoke"] }
    },
    {
      "id": "pidex.project-pipeline.browser-smoke.qa-verdict",
      "agent": "pidex-qa",
      "phases": ["qa"],
      "path": "rules/pidex-qa/browser-smoke-verdict.md",
      "authority": "module-scoped",
      "summary": "Project Pipeline QA browser-smoke verdict rules",
      "audience_scope": "project-pipeline",
      "applies_when": { "mode": "project-pipeline", "capabilities": ["project-pipeline.browser-smoke"] }
    },
    {
      "id": "pidex.project-pipeline.browser-smoke.uat-request",
      "agent": "pidex-uat",
      "phases": ["uat"],
      "path": "rules/pidex-uat/browser-smoke-request.md",
      "authority": "module-scoped",
      "summary": "Project Pipeline UAT browser-smoke request rules",
      "audience_scope": "project-pipeline",
      "applies_when": { "mode": "project-pipeline", "capabilities": ["project-pipeline.browser-smoke"] }
    },
    {
      "id": "pidex.project-pipeline.browser-smoke.uat-verdict",
      "agent": "pidex-uat",
      "phases": ["uat"],
      "path": "rules/pidex-uat/browser-smoke-verdict.md",
      "authority": "module-scoped",
      "summary": "Project Pipeline UAT browser-smoke verdict rules",
      "audience_scope": "project-pipeline",
      "applies_when": { "mode": "project-pipeline", "capabilities": ["project-pipeline.browser-smoke"] }
    },
    {
      "id": "pidex.project-pipeline.browser-smoke.devops-reachability",
      "agent": "pidex-devops",
      "phases": ["devops"],
      "path": "rules/pidex-devops/browser-smoke-reachability.md",
      "authority": "module-scoped",
      "summary": "Project Pipeline DevOps browser-smoke reachability rules",
      "audience_scope": "project-pipeline",
      "applies_when": { "mode": "project-pipeline", "capabilities": ["project-pipeline.browser-smoke"] }
    }
  ],
  "capabilities": [
    {
      "id": "project-pipeline.image",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/image.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^(status|build)$", "^--tag$", "^--json$", "^[A-Za-z0-9_.:/@-]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.lifecycle",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "qa", "security", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-qa", "pidex-security", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/lifecycle.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^(create|open|repair|remove)$", "^--(pidex-root|name|project-id|image|confirm|test-project)$", "^--json$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.import-local",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/import-local.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^--(pidex-root|project-id|source)$", "^--json$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.clone",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/clone.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^--(pidex-root|project-id|url|branch)$", "^--json$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.credentials",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/credentials.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^(copy-git|copy-pi|copy-provider|status|reset)$", "^--(pidex-root|project-id|ssh-key|known-hosts|gitconfig|git-credentials|pi-auth|pi-settings|pi-models|codex-auth|codex-config|gemini-oauth|gemini-settings)$", "^--(json|acknowledge-trusted-persistent-container)$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.run-agent",
      "kind": "tool",
      "phases": ["implementation", "qa", "security", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-implementer", "pidex-qa", "pidex-security", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/run-agent.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^--(pidex-root|project-id|agent|task)$", "^--json$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.mode-resolver",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/mode-resolver.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^--(pidex-root|project-root|mode|source)$", "^--json$", "^(host-direct|hardened-pipeline|project-pipeline)$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.run-flow",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "qa", "security", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-qa", "pidex-security", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/run-flow.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allow_absolute_project_paths": true,
          "allowed_absolute_roots": ["__PIDEX_ROOT__", "__HOME__/.pi/agent", "__HOME__/.codex"],
          "allowed_value_patterns": { "--task": ["^[\\s\\S]{1,20000}$"] },
          "allowed_patterns": ["^--(pidex-root|project-id|name|image|source|url|branch|agent|task|test-project|pi-auth|pi-settings|codex-auth)$", "^--(json|acknowledge-trusted-persistent-container)$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.orchestrator",
      "kind": "tool",
      "phases": ["preflight", "planning", "implementation", "qa", "security", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-qa", "pidex-security", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts", "external-side-effects"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/orchestrator.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allow_absolute_project_paths": true,
          "allowed_absolute_roots": ["__PIDEX_ROOT__", "__HOME__/.pi/agent", "__HOME__/.codex"],
          "allowed_value_patterns": { "--task": ["^[\\s\\S]{1,20000}$"] },
          "allowed_patterns": ["^--(pidex-root|project-id|name|image|source|url|branch|task|phases|test-project|pi-auth|pi-settings|codex-auth)$", "^--(json|acknowledge-trusted-persistent-container)$", "^[A-Za-z0-9_.:/@\\ ,-]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.browser-smoke",
      "kind": "check",
      "phases": ["qa", "uat", "devops"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-qa", "pidex-uat", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["writes-artifacts"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/browser-smoke-bridge.mjs"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_absolute_roots": ["__PIDEX_ROOT__"],
          "allowed_patterns": ["^--(project-id|request|json)$", "^[A-Za-z0-9_.:/@\\ -]+$"]
        }
      }
    },
    {
      "id": "project-pipeline.status",
      "kind": "check",
      "phases": ["preflight", "planning", "implementation", "qa", "security", "devops", "maintenance"],
      "scope": "install",
      "importance": "optional",
      "allowed_agents": ["orchestrator", "pidex-planner", "pidex-implementer", "pidex-qa", "pidex-security", "pidex-devops", "pidex-pi"],
      "supported_platforms": ["linux", "wsl2", "windows-native", "windows-git-bash"],
      "mutability": ["read-only"],
      "command": {
        "bin": "node",
        "args": ["modules/pidex/project-pipeline/scripts/project-pipeline/status.mjs", "--json"],
        "passthrough": true,
        "passthrough_policy": {
          "allowed_patterns": ["^--json$", "^--project-id$", "^[A-Za-z0-9_.-]+$"]
        }
      }
    }
  ]
}
